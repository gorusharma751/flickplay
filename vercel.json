{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "build",
  "env": {
    "REACT_APP_URL": "https://flickplay.vercel.app"
  },
  "regions": ["iad1"],
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true,
      "features": false,
      "develop": false
    }
  },
  "github": {
    "enabled": true,
    "autoAlias": false,
    "autoAssignCustomDomains": false
  },
  "public": false
}
